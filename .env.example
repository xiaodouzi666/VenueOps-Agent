# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-3-pro

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=venueops_demo

# MongoDB MCP
MDB_MCP_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
VENUEOPS_USE_REAL_MCP=false
MDB_MCP_READ_ONLY=true

# Safety
VENUEOPS_ALLOWED_DB=venueops_demo
VENUEOPS_DEMO_MODE=true
VENUEOPS_MAX_QUERY_LIMIT=100

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
